# Copy this file to .env and fill in your key.
# Get a key from https://platform.deepseek.com

DEEPSEEK_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# To use Qwen (DashScope) instead, set:
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL=qwen-coder-plus
# and put your DashScope key in DEEPSEEK_API_KEY
